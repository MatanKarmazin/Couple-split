rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function householdData(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId)).data;
    }

    function isHouseholdMember(householdId) {
      return signedIn() && request.auth.uid in householdData(householdId).memberIds;
    }

    function validHouseholdCreate() {
      return signedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.defaultCurrency == "ILS"
        && request.resource.data.inviteCode is string
        && request.resource.data.name is string;
    }

    function validExpenseCreate(householdId) {
      return isHouseholdMember(householdId)
        && request.resource.data.householdId == householdId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.amountMinor is int
        && request.resource.data.amountMinor > 0
        && request.resource.data.currency == "ILS"
        && request.resource.data.description is string
        && request.resource.data.category is string
        && request.resource.data.paidByUid in householdData(householdId).memberIds
        && request.resource.data.participants is list
        && request.resource.data.splitType in ["equal", "exact", "percentage", "shares"];
    }

    function validSettlementCreate(householdId) {
      return isHouseholdMember(householdId)
        && request.resource.data.householdId == householdId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.amountMinor is int
        && request.resource.data.amountMinor > 0
        && request.resource.data.currency == "ILS"
        && request.resource.data.fromUid in householdData(householdId).memberIds
        && request.resource.data.toUid in householdData(householdId).memberIds
        && request.resource.data.fromUid != request.resource.data.toUid;
    }

    // Users can manage only their own profile document.
    match /users/{uid} {
      allow read, create, update: if isSelf(uid) && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /households/{householdId} {
      // A new household must include the creator as a member.
      allow create: if validHouseholdCreate();
      allow read: if isHouseholdMember(householdId);
      // Existing members can update household metadata and memberIds; ownership spoofing is blocked.
      allow update: if isHouseholdMember(householdId)
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.defaultCurrency == "ILS";
      allow delete: if false;

      match /members/{uid} {
        allow read: if isHouseholdMember(householdId);
        // Members may create their own member record only in households they belong to.
        allow create: if isSelf(uid)
          && request.auth.uid in householdData(householdId).memberIds
          && request.resource.data.uid == request.auth.uid;
        allow update: if isSelf(uid) && isHouseholdMember(householdId);
        allow delete: if false;
      }

      match /expenses/{expenseId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if validExpenseCreate(householdId);
        // Members may edit or soft-delete expenses, but cannot change creator identity.
        allow update: if isHouseholdMember(householdId)
          && request.resource.data.createdByUid == resource.data.createdByUid
          && request.resource.data.householdId == householdId;
        allow delete: if false;
      }

      match /settlements/{settlementId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if validSettlementCreate(householdId);
        allow update: if isHouseholdMember(householdId)
          && request.resource.data.createdByUid == resource.data.createdByUid
          && request.resource.data.householdId == householdId;
        allow delete: if false;
      }
    }
  }
}
