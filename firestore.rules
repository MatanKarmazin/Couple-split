rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function householdData(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId)).data;
    }

    function isHouseholdMember(householdId) {
      return signedIn() && request.auth.uid in householdData(householdId).memberIds;
    }

    function validHouseholdCreate() {
      return signedIn()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.defaultCurrency == "ILS"
        && request.resource.data.inviteCode is string
        && request.resource.data.name is string;
    }

    function validInviteCreate(inviteCode) {
      return signedIn()
        && request.resource.data.householdId is string
        && request.resource.data.createdByUid == request.auth.uid
        && householdData(request.resource.data.householdId).createdByUid == request.auth.uid
        && householdData(request.resource.data.householdId).inviteCode == inviteCode;
    }

    function validJoinProofCreate(inviteCode, uid) {
      return isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.householdId == get(/databases/$(database)/documents/inviteCodes/$(inviteCode)).data.householdId;
    }

    function validHouseholdJoin(householdId) {
      return signedIn()
        && !(request.auth.uid in resource.data.memberIds)
        && resource.data.memberIds.size() < 2
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["memberIds", "updatedAt"])
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() == resource.data.memberIds.size() + 1
        && exists(/databases/$(database)/documents/inviteCodes/$(resource.data.inviteCode)/joins/$(request.auth.uid));
    }

    function validExpenseParticipants(householdId) {
      return request.resource.data.participants is list
        && request.resource.data.participants.size() == householdData(householdId).memberIds.size()
        && request.resource.data.participants.hasAll(householdData(householdId).memberIds)
        && householdData(householdId).memberIds.hasAll(request.resource.data.participants);
    }

    function validExpenseCreate(householdId) {
      return isHouseholdMember(householdId)
        && request.resource.data.householdId == householdId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.amountMinor is int
        && request.resource.data.amountMinor > 0
        && request.resource.data.currency == "ILS"
        && request.resource.data.description is string
        && request.resource.data.category is string
        && request.resource.data.paidByUid in householdData(householdId).memberIds
        && request.resource.data.splitType == "equal"
        && validExpenseParticipants(householdId);
    }

    function validSettlementCreate(householdId) {
      return isHouseholdMember(householdId)
        && request.resource.data.householdId == householdId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.amountMinor is int
        && request.resource.data.amountMinor > 0
        && request.resource.data.currency == "ILS"
        && request.resource.data.fromUid in householdData(householdId).memberIds
        && request.resource.data.toUid in householdData(householdId).memberIds
        && request.resource.data.fromUid != request.resource.data.toUid;
    }

    function validSettlementSoftDelete(householdId) {
      return isHouseholdMember(householdId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["deletedAt", "updatedAt"])
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.householdId == householdId;
    }

    function validRecurringBillWrite(householdId) {
      return isHouseholdMember(householdId)
        && request.resource.data.householdId == householdId
        && request.resource.data.amountMinor is int
        && request.resource.data.amountMinor > 0
        && request.resource.data.currency == "ILS"
        && request.resource.data.description is string
        && request.resource.data.category is string
        && request.resource.data.paidByUid in householdData(householdId).memberIds
        && request.resource.data.dayOfMonth is int
        && request.resource.data.dayOfMonth >= 1
        && request.resource.data.dayOfMonth <= 31
        && request.resource.data.startMonth is string
        && (
          !request.resource.data.keys().hasAny(["frequencyMonths"])
          || request.resource.data.frequencyMonths in [1, 2]
        )
        && request.resource.data.active is bool;
    }

    // Users can manage only their own profile document.
    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create, update: if isSelf(uid) && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /inviteCodes/{inviteCode} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if validInviteCreate(inviteCode);
      allow update, delete: if false;

      match /joins/{uid} {
        allow create: if validJoinProofCreate(inviteCode, uid);
        allow read, update, delete: if false;
      }
    }

    match /households/{householdId} {
      // A new household must include the creator as a member.
      allow create: if validHouseholdCreate();
      allow read: if isHouseholdMember(householdId);
      // Existing members can update household metadata and memberIds; ownership spoofing is blocked.
      allow update: if (
        isHouseholdMember(householdId)
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.defaultCurrency == "ILS"
      ) || validHouseholdJoin(householdId);
      allow delete: if false;

      match /members/{uid} {
        allow read: if isHouseholdMember(householdId);
        // Members may create their own member record only in households they belong to.
        allow create: if isSelf(uid)
          && request.auth.uid in householdData(householdId).memberIds
          && request.resource.data.uid == request.auth.uid;
        allow update: if isSelf(uid) && isHouseholdMember(householdId);
        allow delete: if false;
      }

      match /expenses/{expenseId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if validExpenseCreate(householdId);
        // Members may edit or soft-delete expenses, but cannot change creator identity.
        allow update: if isHouseholdMember(householdId)
          && request.resource.data.createdByUid == resource.data.createdByUid
          && request.resource.data.householdId == householdId
          && request.resource.data.splitType == "equal"
          && validExpenseParticipants(householdId);
        allow delete: if false;
      }

      match /recurringBills/{recurringBillId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if validRecurringBillWrite(householdId)
          && request.resource.data.createdByUid == request.auth.uid;
        allow update: if validRecurringBillWrite(householdId)
          && request.resource.data.createdByUid == resource.data.createdByUid;
        allow delete: if false;
      }

      match /settlements/{settlementId} {
        allow read: if isHouseholdMember(householdId);
        allow create: if validSettlementCreate(householdId);
        allow update: if validSettlementSoftDelete(householdId);
        allow delete: if false;
      }
    }
  }
}
